{% extends 'base.html.twig' %}

{% block body %}
    <h1>Ingredients :</h1>

    <table>
        <thead>
        <tr>
            <th>Name</th>
            <th>Quantity</th>
            <th>Use</th>
        </tr>
        </thead>
        {% for ingredient in ingredients %}
            <tr>
                <td>{{ ingredient.name }}</td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}
